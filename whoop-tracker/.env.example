# WHOOP OAuth 2.0 application credentials.
# Create an app at https://developer.whoop.com/ and copy the values here,
# then `cp .env.example .env` and fill in the real values. .env is gitignored.

# OAuth client credentials from your WHOOP developer app.
WHOOP_CLIENT_ID=your_client_id_here
WHOOP_CLIENT_SECRET=your_client_secret_here

# Must EXACTLY match a redirect URI registered on the WHOOP app.
# The bundled local callback server listens on this host/port/path.
WHOOP_REDIRECT_URI=http://localhost:8080/callback

# Passphrase used to derive the Fernet key that encrypts the local token file.
# Choose something strong; without it the stored tokens cannot be decrypted.
WHOOP_TOKEN_KEY=change-me-to-a-long-random-passphrase
