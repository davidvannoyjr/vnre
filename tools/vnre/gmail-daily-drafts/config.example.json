{
  "_note": "Edit this file freely — it is re-read on every run, no restart needed. All string matching is case-insensitive. Patterns in no_reply_patterns are Python regexes.",

  "lookback_hours": 24,
  "draft_cap": 15,

  "no_reply_patterns": [
    "no.?reply",
    "noreply",
    "do.?not.?reply",
    "donotreply",
    "notifications?@",
    "alerts?@",
    "updates?@",
    "newsletter@",
    "mailer-daemon@",
    "bounce@",
    "postmaster@",
    "automated@",
    "system@",
    "support-noreply@",
    "info@(?!.*(?:client|lead|transaction))",
    "news@",
    "digest@",
    "robot@"
