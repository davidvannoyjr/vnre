# ── Copy to .env.local and fill in. NEVER commit real values. ──────────────

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database (Postgres). Leave UNSET to run without a DB (JWT sessions, everyone
# "free", no billing). Set it to enable persistent members + Stripe billing.
# Local: a Docker Postgres or a free hosted DB (Neon, Supabase, Railway).
# After setting, run: npm run db:push
DATABASE_URL=postgresql://user:pass@localhost:5432/dvn_ai_lab

# Auth (Auth.js v5 / NextAuth)
# Generate: openssl rand -base64 32
AUTH_SECRET=
# Email magic-link provider (recommended for agents — no passwords)
AUTH_EMAIL_SERVER=smtp://user:pass@smtp.host:587
AUTH_EMAIL_FROM=members@yourdomain.com
# Optional Google sign-in
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Stripe (subscription billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Price IDs for each tier (create in Stripe dashboard → Products)
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...
# 1:1 coaching ($1,000/mo) — invite-only; coach generates checkout links per client.
STRIPE_PRICE_COACHING=price_...

# Coaching: emails granted coach access (comma-separated). DVN's address goes here.
COACH_EMAILS=david@vannoyre.com

# Content automation (used by GitHub Action that drafts approved topics)
# Anthropic API key for the auto-drafter. Keep in GitHub repo secrets, not here.
ANTHROPIC_API_KEY=
