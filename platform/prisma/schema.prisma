// Persistent layer for members + billing. Used when DATABASE_URL is set.
// The app still boots without it (JWT sessions, everyone "free") — see lib/auth.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth.js (NextAuth) adapter models ────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // member | coach. Coaches manage 1:1 clients; see lib/coaching.ts.
  role String @default("member")

  // Billing — kept on the user for fast tier reads in the session callback.
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  // Resolved subscription tier: free | basic | pro | elite | coaching.
  tier                   String    @default("free")

  // 1:1 coaching relationships.
  coachingProfile ClientProfile?  @relation("ClientUser")
  coachedClients  ClientProfile[] @relation("CoachUser")
  authoredNotes   CoachingNote[]
  lessonProgress  LessonProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// A member marking a tutorial complete (progress tracking).
model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String // tutorial slug
  completedAt DateTime @default(now())

  @@unique([userId, slug])
}

// ── 1:1 Coaching workspace ────────────────────────────────────────────────────

// One per coaching client: links the client user to their coach (DVN).
model ClientProfile {
  id        String   @id @default(cuid())
  clientId  String   @unique
  client    User     @relation("ClientUser", fields: [clientId], references: [id], onDelete: Cascade)
  coachId   String
  coach     User     @relation("CoachUser", fields: [coachId], references: [id])
  status    String   @default("active") // active | paused | ended
  startedAt DateTime @default(now())

  plan  BusinessPlan?
  notes CoachingNote[]
  tasks CoachingTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// The client's current business plan (shared — both coach and client edit).
model BusinessPlan {
  id              String        @id @default(cuid())
  clientProfileId String        @unique
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  content         String        @default("")
  updatedAt       DateTime      @updatedAt
}

// Coaching notes. Coach-private by default; shareWithClient flips visibility.
model CoachingNote {
  id               String        @id @default(cuid())
  clientProfileId  String
  clientProfile    ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  authorId         String
  author           User          @relation(fields: [authorId], references: [id])
  body             String
  sharedWithClient Boolean       @default(false)
  createdAt        DateTime      @default(now())
}

// A task tied to the five-stage coaching outline.
model CoachingTask {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  stage           String        @default("forge") // forge|conquer|anchor|architect|own
  title           String
  detail          String        @default("")
  status          String        @default("todo") // todo | done
  dueDate         DateTime?
  completedAt     DateTime?
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
}
